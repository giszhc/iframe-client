{
  "name": "@giszhc/iframe-client",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/iframe-client.umd.cjs",
  "module": "./dist/iframe-client.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/iframe-client.js",
      "require": "./dist/iframe-client.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:example": "vite build --config vite.example.config.ts"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "@types/node": "^22.4.0"
  },
  "keywords": [
    "iframe",
    "client",
    "communication",
    "postMessage"
  ],
  "description": "一个 简单、轻量、专注通信 的 JavaScript / TypeScript 库，用于 iframe 跨域消息传递。",
  "author": "giszhc",
  "license": "MIT",
  "homepage": "https://github.com/giszhc/iframe-client#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/giszhc/iframe-client.git"
  },
  "bugs": {
    "url": "https://github.com/giszhc/iframe-client/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
